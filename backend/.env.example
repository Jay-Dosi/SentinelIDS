APP_NAME=SentinelIDS
APP_VERSION=1.0.0
DEBUG=false

DATABASE_URL=postgresql://sentinel:sentinel@localhost:5432/sentinelids

MODELS_DIR=models
DATASETS_DIR=datasets

# ── Training ──────────────────────────────────────────────
EPOCHS=60
BATCH_SIZE=1024
LEARNING_RATE=0.0005
TEST_SPLIT=0.2
RANDOM_SEED=42
ANOMALY_THRESHOLD_PERCENTILE=95

# ── Sampling caps ─────────────────────────────────────────
# BENIGN is capped at this many samples (undersampling)
BENIGN_CAP=500000
# Any class with fewer than this gets oversampled up to this
MIN_CLASS_SAMPLES=200

# ── Focal loss gamma (higher = more focus on hard/rare classes) ──
FOCAL_LOSS_GAMMA=1.5

# ── Threat weights ────────────────────────────────────────
CLASSIFIER_WEIGHT=0.6
ANOMALY_WEIGHT=0.3
SIGNATURE_WEIGHT=0.1

TORCH_EXTRA_INDEX_URL=https://download.pytorch.org/whl/cu121

ATTACK_CAP=150000